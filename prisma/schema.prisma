// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
}

model Tote {
  id        Int          @id @default(autoincrement())
  title     String
  items     ToteItem[]
  photos    TotePhoto[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ToteItem {
  id          Int    @id @default(autoincrement())
  toteId      Int
  tote        Tote   @relation(fields: [toteId], references: [id], onDelete: Cascade)
  description String @db.VarChar(100)
  position    Int
}

model TotePhoto {
  id        Int      @id @default(autoincrement())
  toteId    Int
  tote      Tote     @relation(fields: [toteId], references: [id], onDelete: Cascade)
  filename  String
  createdAt DateTime @default(now())
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model TodoItem {
  id        Int       @id @default(autoincrement())
  title     String
  notes     String?
  dueDate   DateTime?
  priority  Priority  @default(MEDIUM)
  category  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── Grocery ─────────────────────────────────────────────────────
model GroceryStore {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  position  Int           @default(0)
  createdAt DateTime      @default(now())
  lists     GroceryList[]
}

model GroceryArea {
  id        Int               @id @default(autoincrement())
  name      String            @unique
  position  Int               @default(0)
  createdAt DateTime          @default(now())
  items     GroceryListItem[]
}

enum GroceryListStatus {
  ACTIVE
  COMPLETED
}

model GroceryList {
  id        Int               @id @default(autoincrement())
  storeId   Int
  store     GroceryStore      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  status    GroceryListStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  items     GroceryListItem[]
  trips     GroceryTrip[]
}

model GroceryListItem {
  id        Int          @id @default(autoincrement())
  listId    Int
  list      GroceryList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  areaId    Int?
  area      GroceryArea? @relation(fields: [areaId], references: [id], onDelete: SetNull)
  name      String
  quantity  String?
  purchased Boolean      @default(false)
  position  Int          @default(0)
  createdAt DateTime     @default(now())
}

model GroceryTrip {
  id          Int               @id @default(autoincrement())
  listId      Int
  list        GroceryList       @relation(fields: [listId], references: [id])
  storeName   String
  completedAt DateTime          @default(now())
  items       GroceryTripItem[]
}

model GroceryTripItem {
  id        Int         @id @default(autoincrement())
  tripId    Int
  trip      GroceryTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name      String
  quantity  String?
  areaName  String?
  purchased Boolean
}

// ─── Packages ─────────────────────────────────────────────────────
enum Carrier {
  USPS
  UPS
  FEDEX
}

enum PackageStatus {
  UNKNOWN
  PENDING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
}

model Package {
  id                Int           @id @default(autoincrement())
  trackingNumber    String        @unique
  carrier           Carrier
  description       String?
  status            PackageStatus @default(UNKNOWN)
  statusDetail      String?
  estimatedDelivery DateTime?
  delivered         Boolean       @default(false)
  sourceEmail       String?
  shipperName       String?
  originCity        String?
  originState       String?
  events            Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// ─── Email Digest ──────────────────────────────────────────────────
model ApprovedSender {
  id        Int      @id @default(autoincrement())
  value     String   @unique   // e.g. "orders@amazon.com" or "@amazon.com"
  label     String?            // optional display name, e.g. "Amazon"
  createdAt DateTime @default(now())
}

model EmailDigest {
  id         Int      @id @default(autoincrement())
  reportDate DateTime @unique   // midnight UTC for the day
  totalCount Int
  entries    Json     // [{ sender: string, count: number }]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Recipes ──────────────────────────────────────────────────────
model Recipe {
  id          Int                @id @default(autoincrement())
  title       String
  servings    String?
  sourceUrl   String?
  notes       String?            @db.Text
  tags        String[]
  ingredients RecipeIngredient[]
  steps       RecipeStep[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model RecipeIngredient {
  id       Int    @id @default(autoincrement())
  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  quantity String?
  unit     String?
  name     String
  position Int
}

model RecipeStep {
  id          Int    @id @default(autoincrement())
  recipeId    Int
  recipe      Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stepNumber  Int
  instruction String @db.Text
}
