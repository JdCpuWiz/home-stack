// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
}

model Tote {
  id        Int          @id @default(autoincrement())
  title     String
  items     ToteItem[]
  photos    TotePhoto[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ToteItem {
  id          Int    @id @default(autoincrement())
  toteId      Int
  tote        Tote   @relation(fields: [toteId], references: [id], onDelete: Cascade)
  description String @db.VarChar(100)
  position    Int
}

model TotePhoto {
  id        Int      @id @default(autoincrement())
  toteId    Int
  tote      Tote     @relation(fields: [toteId], references: [id], onDelete: Cascade)
  filename  String
  createdAt DateTime @default(now())
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model TodoItem {
  id        Int       @id @default(autoincrement())
  title     String
  notes     String?
  dueDate   DateTime?
  priority  Priority  @default(MEDIUM)
  category  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── Grocery ─────────────────────────────────────────────────────
model GroceryStore {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  position  Int           @default(0)
  createdAt DateTime      @default(now())
  lists     GroceryList[]
}

enum GroceryListStatus {
  ACTIVE
  COMPLETED
}

model GroceryList {
  id        Int               @id @default(autoincrement())
  storeId   Int
  store     GroceryStore      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  status    GroceryListStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  items     GroceryListItem[]
  trips     GroceryTrip[]
}

model GroceryListItem {
  id        Int          @id @default(autoincrement())
  listId    Int
  list      GroceryList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  category  String?
  name      String
  quantity  String?
  purchased Boolean      @default(false)
  position  Int          @default(0)
  createdAt DateTime     @default(now())
}

model GroceryTrip {
  id          Int               @id @default(autoincrement())
  listId      Int
  list        GroceryList       @relation(fields: [listId], references: [id])
  storeName   String
  completedAt DateTime          @default(now())
  items       GroceryTripItem[]
}

model GroceryTripItem {
  id        Int         @id @default(autoincrement())
  tripId    Int
  trip      GroceryTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name      String
  quantity  String?
  areaName  String?
  purchased Boolean
}

// ─── Packages ─────────────────────────────────────────────────────
enum Carrier {
  USPS
  UPS
  FEDEX
}

enum PackageStatus {
  UNKNOWN
  PENDING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
}

model Package {
  id                Int           @id @default(autoincrement())
  trackingNumber    String        @unique
  carrier           Carrier
  description       String?
  status            PackageStatus @default(UNKNOWN)
  statusDetail      String?
  estimatedDelivery DateTime?
  delivered         Boolean       @default(false)
  sourceEmail       String?
  shipperName       String?
  originCity        String?
  originState       String?
  events            Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// ─── Email Digest ──────────────────────────────────────────────────
model ApprovedSender {
  id          Int      @id @default(autoincrement())
  value       String   @unique   // e.g. "orders@amazon.com" or "@amazon.com"
  label       String?            // optional display name, e.g. "Amazon"
  priority    String   @default("NORMAL")  // "HIGH" | "NORMAL" | "LOW"
  description String?            // Ollama-generated, stored for HIGH priority senders
  createdAt   DateTime @default(now())
}

model EmailDigest {
  id              Int       @id @default(autoincrement())
  startedAt       DateTime  @default(now())  // when this accumulation period began
  clearedAt       DateTime?                  // null = current active digest
  totalCount      Int       @default(0)
  unapprovedCount Int       @default(0)
  entries         Json      @default("[]")   // [{ sender: string, count: number }]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model EmailSummary {
  id        Int      @id @default(autoincrement())
  sender    String
  subject   String
  summary   String
  createdAt DateTime @default(now())
}

// ─── Finance ──────────────────────────────────────────────────────
enum FinanceCategory {
  BILLS
  SUBSCRIPTIONS
  SHARED_CREDIT
  MY_CARDS
  SHARED_CARDS
  LOANS
  UNPLANNED
}

model FinanceBudgetItem {
  id            Int                  @id @default(autoincrement())
  name          String
  category      FinanceCategory
  defaultAmount Decimal?             @db.Decimal(10, 2)
  payDay        Int?
  isActive      Boolean              @default(true)
  position      Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  entries       FinanceBudgetEntry[]
}

model FinanceMonth {
  id             Int                  @id @default(autoincrement())
  year           Int
  month          Int
  netPay         Decimal?             @db.Decimal(10, 2)
  netPayIsManual Boolean              @default(false)
  archivedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  entries        FinanceBudgetEntry[]

  @@unique([year, month])
}

model FinanceBudgetEntry {
  id             Int                @id @default(autoincrement())
  monthId        Int
  month          FinanceMonth       @relation(fields: [monthId], references: [id], onDelete: Cascade)
  itemId         Int?
  item           FinanceBudgetItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  subscriptionId Int?
  subscription   Subscription?      @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  name           String
  category       FinanceCategory
  amount         Decimal            @db.Decimal(10, 2)
  payDay         Int?
  isPaid         Boolean            @default(false)
  paidAt         DateTime?
  notes          String?
  position       Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

// ─── Pantry ───────────────────────────────────────────────────────
model PantryCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  icon      String   @default("Package")
  position  Int      @default(0)
  createdAt DateTime @default(now())
}

model PantryProduct {
  id        Int      @id @default(autoincrement())
  barcode   String   @unique
  name      String
  brand     String?
  size      String?
  photoUrl  String?
  category  String?
  quantity  Int      @default(0)
  minQty    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Subscriptions ────────────────────────────────────────────────
enum SubscriptionFrequency {
  MONTHLY
  QUARTERLY
  BIANNUAL
  ANNUAL
}

model Subscription {
  id            Int                   @id @default(autoincrement())
  name          String
  cost          Decimal               @db.Decimal(10, 2)
  frequency     SubscriptionFrequency
  renewalDate   DateTime              @db.Date
  paymentMethod String?
  website       String?
  category      String?
  notes         String?
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  entries       FinanceBudgetEntry[]
}

// ─── Recipes ──────────────────────────────────────────────────────
model Recipe {
  id          Int                @id @default(autoincrement())
  title       String
  servings    String?
  sourceUrl   String?
  notes       String?            @db.Text
  tags        String[]
  ingredients RecipeIngredient[]
  steps       RecipeStep[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model RecipeIngredient {
  id       Int    @id @default(autoincrement())
  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  quantity String?
  unit     String?
  name     String
  position Int
}

model RecipeStep {
  id          Int    @id @default(autoincrement())
  recipeId    Int
  recipe      Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stepNumber  Int
  instruction String @db.Text
}
