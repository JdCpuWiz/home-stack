DATABASE_URL="postgresql://user:password@host:5432/homestack?schema=public"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://homestack.yourdomain.com"
PORT=3000
PUID=1000
PGID=1000
TZ=America/New_York

# Ollama — used by the Recipes "Scan" feature to parse recipes from text or photos
# Set OLLAMA_URL to your Ollama instance. Defaults to http://localhost:11434 if omitted.
# Set OLLAMA_URL to your Ollama instance. Defaults to http://localhost:11434 if omitted.
# Recommended models (must be multimodal for photo scan):
#   qwen2.5vl:7b         — best choice: reliable JSON output, fast, good vision quality
#   llama3.2-vision:11b  — good alternative, slightly less consistent JSON formatting
OLLAMA_URL="http://192.168.1.100:11434"
OLLAMA_MODEL="qwen2.5vl:7b"

# API key for server-to-server access (n8n workflows, etc.)
# Generate with: openssl rand -base64 32
HOMESTACK_API_KEY="generate-with-openssl-rand-base64-32"

# Home Assistant webhook URL for pantry/kiosk stock notifications (optional)
# Format: http://<ha-host>:8123/api/webhook/homestack_pantry
# Leave unset to disable HA notifications.
HA_WEBHOOK_URL=""
